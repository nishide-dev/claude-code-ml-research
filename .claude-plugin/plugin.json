{
  "name": "ml-research",
  "version": "0.1.0",
  "description": "Comprehensive Machine Learning research plugin for Claude Code. Provides project scaffolding, experiment management, training support, and debugging tools for PyTorch Lightning, Hydra, PyTorch Geometric, and Hugging Face Transformers.",
  "author": "ML Research Team",
  "homepage": "https://github.com/nishide-dev/claude-code-ml-research",
  "repository": "https://github.com/nishide-dev/claude-code-ml-research",
  "license": "MIT",
  "keywords": [
    "machine-learning",
    "pytorch",
    "pytorch-lightning",
    "hydra",
    "pytorch-geometric",
    "transformers",
    "ml-research",
    "pixi",
    "uv",
    "ruff",
    "wandb"
  ],
  "skills": [
    "./skills/",
    "./commands/"
  ],
  "agents": [
    "./agents/ml-architect.md",
    "./agents/config-generator.md",
    "./agents/training-debugger.md",
    "./agents/pytorch-expert.md",
    "./agents/geometric-specialist.md"
  ],
  "lspServers": [
    {
      "name": "ty",
      "command": "uvx",
      "args": ["ty@latest", "server"],
      "languages": ["python"]
    },
    {
      "name": "ruff",
      "command": "uvx",
      "args": ["ruff", "server"],
      "languages": ["python"]
    }
  ]
}
